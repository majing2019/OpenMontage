{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openmontage/artifacts/story_seed",
  "title": "Story Seed",
  "description": "A structured comic story idea for short-form Douyin video generation",
  "type": "object",
  "required": [
    "version",
    "seed_id",
    "title",
    "hook",
    "logline",
    "pattern",
    "beats",
    "character_archetypes",
    "suggested_style"
  ],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "seed_id": {
      "type": "string",
      "description": "Unique identifier for this seed"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Short title for the story"
    },
    "hook": {
      "type": "string",
      "description": "Opening hook — the first thing the audience sees/reads"
    },
    "logline": {
      "type": "string",
      "description": "One-sentence story summary"
    },
    "pattern": {
      "type": "string",
      "description": "Story pattern name (e.g. 身份反转, 误会连环)"
    },
    "pattern_category": {
      "type": "string",
      "description": "Pattern category (emotional, comedy, suspense, slice_of_life, social)"
    },
    "douyin_tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suggested Douyin hashtags"
    },
    "emotion_arc": {
      "type": "object",
      "description": "Emotional trajectory of the story",
      "properties": {
        "starts": { "type": "string" },
        "peaks_at": { "type": "string" },
        "ends": { "type": "string" }
      },
      "required": ["starts", "peaks_at", "ends"]
    },
    "beats": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "description": "5-beat narrative structure with timing",
      "items": {
        "type": "object",
        "required": ["beat_number", "name", "start_second", "end_second", "description", "visual_suggestion"],
        "properties": {
          "beat_number": { "type": "integer", "minimum": 1, "maximum": 5 },
          "name": { "type": "string", "description": "Beat name (HOOK, BUILD, CONFRONT, REVEAL, RESOLVE)" },
          "start_second": { "type": "number", "minimum": 0 },
          "end_second": { "type": "number" },
          "description": { "type": "string", "description": "What happens in this beat" },
          "visual_suggestion": { "type": "string", "description": "Visual direction for image generation" },
          "text_overlay": { "type": "string", "description": "Suggested on-screen text" },
          "camera_hint": { "type": "string", "description": "Shot size and angle suggestion" }
        }
      }
    },
    "twist": {
      "type": "string",
      "description": "The twist or reveal moment"
    },
    "ending": {
      "type": "string",
      "description": "How the story resolves"
    },
    "character_archetypes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "description": "Character archetypes for this story",
      "items": {
        "type": "object",
        "required": ["role", "description"],
        "properties": {
          "role": { "type": "string" },
          "description": { "type": "string" },
          "emotional_state": { "type": "string" },
          "visual_notes": { "type": "string", "description": "Fixed character description for consistent image generation" }
        }
      }
    },
    "suggested_style": {
      "type": "object",
      "description": "Visual style preset for Seedream image generation",
      "properties": {
        "color_palette": { "type": "string" },
        "mood": { "type": "string" },
        "lighting": { "type": "string" },
        "seedream_keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keywords to append to every Seedream prompt"
        }
      }
    },
    "visual_keywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Scene-specific visual keywords"
    },
    "target_platform": {
      "type": "string",
      "enum": ["douyin", "tiktok", "instagram", "youtube_shorts", "generic"]
    },
    "target_duration_seconds": { "type": "number" },
    "estimated_image_count": {
      "type": "integer",
      "description": "Approximate number of distinct images needed"
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"]
    },
    "generation_mode": { "type": "string" },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
